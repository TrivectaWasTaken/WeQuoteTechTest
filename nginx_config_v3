server {
    listen 80;
    server_name 3.8.177.41;

    # Backend API
    location /api {
        alias /var/www/wequote/backend/public;
        try_files $uri $uri/ @api;

        location ~ \.php$ {
            include snippets/fastcgi-php.conf;
            fastcgi_pass unix:/var/run/php/php8.3-fpm.sock;
            fastcgi_param SCRIPT_FILENAME /var/www/wequote/backend/public/index.php;
        }
    }

    location @api {
        rewrite ^/api/(.*)$ /api/index.php?$1 last;
    }

    # Frontend
    location / {
        root /var/www/wequote/public;
        try_files $uri $uri/ /index.html;
    }
}
